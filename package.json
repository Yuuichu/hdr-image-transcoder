{
  "name": "hdr-image-transcoder",
  "version": "0.1.0",
  "description": "Local Electron GUI for HDR image transcoding.",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "prepack": "node scripts/prepare-package.js",
    "pack": "npm run prepack && electron-builder --dir",
    "dist": "npm run prepack && electron-builder"
  },
  "keywords": [
    "hdr",
    "avif",
    "jpeg-xl",
    "gainmap",
    "electron"
  ],
  "author": "Yuuichu",
  "license": "MIT",
  "build": {
    "appId": "com.yuuichu.hdr-image-transcoder",
    "productName": "HDR Image Transcoder",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python"
      }
    ],
    "win": {
      "target": "portable",
      "icon": null
    }
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.0.12"
  }
}
